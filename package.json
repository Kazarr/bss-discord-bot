{
  "name": "bss-discord-bot",
  "version": "1.0.0",
  "description": "Discord bot for collecting game feedback and managing GitHub issues for By Sword and Seal",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@octokit/rest": "^22.0.1",
    "discord.js": "^14.26.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "eslint": "^9.8.0",
    "prettier": "^2.6.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.1.2"
  }
}
